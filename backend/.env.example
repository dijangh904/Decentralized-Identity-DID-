# Backend Environment Variables

# Stellar Network Configuration
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PASSPHRASE=Test SDF Network ; September 2015

# DID Configuration
DID_METHOD=stellar
DID_REGISTRY_PUBLIC_KEY=YOUR_REGISTRY_PUBLIC_KEY

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
MONGODB_URL=mongodb://localhost:27017/stellar-did
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Security Configuration
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Stellar Friendbot (for testnet funding)
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Cross-Chain Bridge (Ethereum/EVM) Configuration
# RPC endpoint for the EVM network (e.g. Sepolia testnet, Polygon, etc.)
EVM_RPC_URL=https://rpc2.sepolia.org
# Private key of the bridge admin wallet (prefixed with 0x)
EVM_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# Deployed EthereumDIDRegistry contract address on the target EVM network
EVM_DID_REGISTRY_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
# Chain ID of the target EVM network (11155111 = Sepolia)
EVM_CHAIN_ID=11155111
